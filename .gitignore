# Rust / Cargo
/target
# Note: Cargo.lock IS committed (cdylib for Python wheel = treat as binary)

# Python
__pycache__/
*.py[cod]
*$py.class
.python-version
.ruff_cache/
.pytest_cache/
.ty_cache/
*.egg-info/
build/
dist/

# maturin develop の配置先 (.so のみ無視; .py / .pyi は VCS 管理)
python/kryanneal/_rust*.so
python/kryanneal/_rust*.pyd
python/kryanneal/_rust*.dylib

# uv
.venv/

# benchmark 結果
# 原則 `benchmarks/results/<timestamped-dir>/` 配下の生 CSV / markdown は
# gitignore. ただし version finalize 時は `benchmarks/results/<X.Y.Z>/`
# (semver そのまま, prefix なし) に **markdown のみ** をコミットして履歴を
# 残す (CSV は引き続き ignore). semver 形式 (`*.*.*`) のディレクトリのみ
# track 対象とし, timestamped dir (`20260512-153531` 等) や ad-hoc dir
# (`m_eff_loose_1` 等) は ignore のままに保つ. 詳細運用は
# benchmarks/README.md と docs/conventions.md §2.3 を参照.
/benchmarks/results/*
!/benchmarks/results/*.*.*/
/benchmarks/results/*.*.*/*
!/benchmarks/results/*.*.*/*.md

# tools/ 配下の検証スクリプト出力 (timestamped CSV / markdown)
/tools/results/

# README figure pipeline の artifact (詳細は benchmarks/README.md
# "Workflow (ローカル ↔ Linux 共有)" 節).
#  - 問題 / 参照解 npz: 数学的に固定で kryanneal version に依存しないため
#    `benchmarks/data/` **直下** に置き version 横断で reuse する.
#    ファイル名 `problem_*.npz` / `reference_*.npz` のみ track.
#  - bench CSV: kryanneal version 固有の wall time なので
#    `benchmarks/data/<X.Y.Z>/` (semver dir) 配下に置き track.
#  - timestamp dir や ad-hoc 名 (`tmp_test` 等) はすべて ignore のまま.
/benchmarks/data/*
!/benchmarks/data/problem_*.npz
!/benchmarks/data/reference_*.npz
!/benchmarks/data/*.*.*/
/benchmarks/data/*.*.*/*
!/benchmarks/data/*.*.*/bench_*.csv

# BLAS 数値一致 artifact (test_blas_consistency.py が `blas_on.npz` /
# `blas_off.npz` を書き込む). 詳細は同テストの docstring 参照.
/tests/artifacts/

# editor / OS
.vscode/
.idea/
.DS_Store

# Claude Code local (per-machine) settings
.claude/settings.local.json

# README figure pipeline の long-running 計算 (run_compute_references.sh) の
# 実行ログ / PID file. run-specific なので ignore. shell script 自体は track.
/compute_references.log
/compute_references.pid

# m_eff probe (probe_m_eff_n18.py) の PID file. probe script + log は track
# (将来 issue #114 の Phase 9 改修や perf 解析で再現に valuable).
/probe_m_eff_n18.pid
