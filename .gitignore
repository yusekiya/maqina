# Rust / Cargo
/target
# Note: Cargo.lock IS committed (cdylib for Python wheel = treat as binary)

# Python
__pycache__/
*.py[cod]
*$py.class
.python-version
.ruff_cache/
.pytest_cache/
.ty_cache/
*.egg-info/
build/
dist/

# maturin develop の配置先 (.so のみ無視; .py / .pyi は VCS 管理)
python/kinema/_rust*.so
python/kinema/_rust*.pyd
python/kinema/_rust*.dylib

# uv
.venv/

# benchmark 結果
# 原則 `benchmarks/results/<timestamped-dir>/` 配下の生 CSV / markdown は
# gitignore. ただし version finalize 時は `benchmarks/results/<X.Y.Z>/`
# (semver そのまま, prefix なし) に **markdown + README figure 用 CSV** を
# コミットして履歴を残す. semver 形式 (`*.*.*`) のディレクトリのみ track
# 対象とし, timestamped dir (`20260512-153531` 等) や ad-hoc dir
# (`m_eff_loose_1` 等) は ignore のままに保つ. 詳細運用は
# benchmarks/README.md と docs/conventions.md §2.3 を参照.
#
# README figure pipeline の例外 (詳細は benchmarks/README.md):
#  - QuTiP CSV: 同一 hardware なら kinema version 非依存なので version
#    dir の外 `benchmarks/results/qutip/` に切り出して共有
#    (tools/extract_qutip_rows.py).
/benchmarks/results/*
!/benchmarks/results/*.*.*/
/benchmarks/results/*.*.*/*
!/benchmarks/results/*.*.*/*.md
!/benchmarks/results/*.*.*/bench_*.csv
!/benchmarks/results/qutip/
/benchmarks/results/qutip/*
!/benchmarks/results/qutip/bench_*.csv

# tools/ 配下の検証スクリプト出力 (timestamped CSV / markdown)
/tools/results/

# README figure pipeline の input (詳細は benchmarks/README.md).
# 問題 / 参照解 npz: 数学的に固定で kinema version に依存しないため
# `benchmarks/data/` **直下** に置き version 横断で reuse する.
# ファイル名 `problem_*.npz` / `reference_*.npz` のみ track.
# 出力 (bench CSV) は version-finalize と同じ `benchmarks/results/<X.Y.Z>/` 配下.
/benchmarks/data/*
!/benchmarks/data/problem_*.npz
!/benchmarks/data/reference_*.npz

# BLAS 数値一致 artifact (test_blas_consistency.py が `blas_on.npz` /
# `blas_off.npz` を書き込む). 詳細は同テストの docstring 参照.
/tests/artifacts/

# editor / OS
.vscode/
.idea/
.DS_Store

# Claude Code local (per-machine) settings
.claude/settings.local.json

# README figure pipeline の long-running 計算 (run_compute_references.sh) の
# 実行ログ / PID file. run-specific なので ignore. shell script 自体は track.
/compute_references.log
/compute_references.pid
